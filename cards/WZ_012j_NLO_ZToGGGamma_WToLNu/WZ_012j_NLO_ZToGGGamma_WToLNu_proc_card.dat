import model loop_sm-ckm_no_b_mass

define l+ = e+ mu+
define l- = e- mu-
define vl = ve vm
define vl~ = ve~ vm~

generate p p > z l+ vl [QCD] @0
add process p p > z l- vl~ [QCD] @0
add process p p > z l+ vl j [QCD] @1
add process p p > z l- vl~ j [QCD] @1
add process p p > z l+ vl j j [QCD] @2
add process p p > z l- vl~ j j [QCD] @2

output WZ_012j_NLO_ZToGGGamma_WToLNu -nojpeg
